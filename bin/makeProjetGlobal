# Non encore achevé

FLAGS_COMPILATION = -Wall `sdl2-config --cflags`
FLAGS_EDITION = `sdl2-config --libs` -lSDL2_image -lSDL2_ttf -lm

REP_SRC = ../src
REP_TEST = ../test

FIC_SRC = $(wildcard $(REP_SRC)/*.c)
FIC_TEST = $(wildcard $(REP_TEST)/*.c)
FIC_OBJETS = $(notdir $(FIC_SRC:.c=.o)) $(notdir $(FIC_TEST:.c=.o))

# Edition de liens

EXECUTABLES = \
./main \
./testBombeDinosTours \
./testBombeDinosToursV2 \
./testFonctionsChangementTour \
./testFonctionsMenuPrinc \
./testFonctionsPagesInformations \
./testFonctionsRebonds \
./testFonctionsTuerDinos \
./testFonctionsVerification \
./main_test

OBJETS_BOMBE_DINOS_TOURS = testBombeDinosTours.o placer_dinos.o gestion_zones.o tda_nuage.o fonctionsChangementTour.o fonctionsPlacementBombe.o fonctionsRebonds.o fonctionsStructJoueur.o fonctionsVerification.o fonctionsTuerDinos.o chargerMatrice.o

OBJETS_BOMBE_DINOS_TOURS_V2 = testBombeDinosToursV2.o \
chargerMatrice.o \
placer_dinos.o \
tda_nuage.o \
gestion_zones.o \
fonctionsStructJoueur.o \
