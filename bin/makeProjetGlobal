# Hannah Sergent

FLAGS_COMPILATION = -Wall `sdl2-config --cflags`
FLAGS_EDITION = `sdl2-config --libs` -lSDL2_image -lSDL2_ttf -lm

REP_SRC = ../src
REP_TEST = ../test

FIC_SRC = $(wildcard $(REP_SRC)/*.c)
FIC_TEST = $(wildcard $(REP_TEST)/*.c)
FIC_OBJETS = $(notdir $(FIC_SRC:.c=.o)) $(notdir $(FIC_TEST:.c=.o))

# Edition de liens

EXECUTABLES = \
./main \
./test_archer \
./test_deplacement \
./testAffichageDinosMap \
./testAffichageMenuHIP \
./testBombeDinosTours \
./testBombeDinosToursV2 \
./testCollisions \
./testFonctionsChangementTour \
./testFonctionsMenuPrinc \
./testFonctionsPageFinPartie \
./testFonctionsPagesInformations \
./testFonctionsRebonds \
./testFonctionsStructJoueur \
./testFonctionsTuerDinos \
./testFonctionsVerification \
./testRegression \
./testTirArmes \
./testTirsAffichageJeu

# Fichiers objets rangés par thème

OBJ_COM = chargerMatrice.o fonctionsStructJoueur.o gestion_zones.o placer_dinos.o tda_nuage.o
OBJ_AFF = fonctionsPageFinPartie.o fonctionsPageJeu.o fonctionsPagesInformations.o fonctionsMenuHIP.o fonctionsMenuPrinc.o fonctionsVerification.o
OBJ_ARMES = fonctionsTirs.o fonctionSoin.o
OBJ_BOMBE = fonctionsPlacementBombe.o fonctionsRebonds.o fonctionsTuerDinos.o
OBJ_DEP = deplacement.o regression.o
OBJ_TOUR = fonctionsChangementTour.o
OBJ_ALL = $(OBJ_COM) $(OBJ_AFF) $(OBJ_ARMES) $(OBJ_BOMBE) $(OBJ_DEP) $(OBJ_TOUR)


OBJETS_MAIN = main.o $(OBJ_ALL)

# Fichiers objets pour les tests

OBJETS_ARCHER = test_archer.o $(OBJ_ALL)
OBJETS_DEPLA = test_deplacement.o $(OBJ_ALL) fonctionsAffichage.o 
OBJETS_AFF_DINOS = testAffichageDinosMap.o $(OBJ_ALL)
OBJETS_AFFICHAGE_HIP = testAffichageMenuHIP.o $(OBJ_ALL)
OBJETS_BOMBE_DINOS_TOURS = testBombeDinosTours.o $(OBJ_COM) $(OBJ_BOMBE) $(OBJ_TOUR) fonctionsMenuHIP.o fonctionsVerification.o
OBJETS_BOMBE_DINOS_TOURS_V2 = testBombeDinosToursV2.o $(OBJ_ALL)
OBJETS_COLLISIONS = testCollisions.o placer_dinos.o testPlacement.o collision_decor.o chargerMatrice.o

OBJETS_CHANGEMENT_TOUR = testFonctionsChangementTour.o  chargerMatrice.o fonctionsChangementTour.o fonctionsStructJoueur.o placer_dinos.o
OBJETS_PAGE_FIN_PARTIE = testFonctionsPageFinPartie.o $(OBJ_ALL)
OBJETS_PAGES_INFOS = testFonctionsPagesInformations.o $(OBJ_ALL)
OBJETS_MENU_PRINC = testFonctionsMenuPrinc.o $(OBJ_ALL)
OBJETS_REBONDS = testFonctionsRebonds.o $(OBJ_COM) $(OBJ_BOMBE) fonctionsMenuHIP.o fonctionsVerification.o
OBJETS_TUER_DINOS = testFonctionsTuerDinos.o $(OBJ_COM) $(OBJ_BOMBE) fonctionsMenuHIP.o fonctionsVerification.o
OBJETS_STRUCT_JOUEUR = testFonctionsStructJoueur.o chargerMatrice.o fonctionsStructJoueur.o placer_dinos.o
OBJETS_VERIFICATION = testFonctionsVerification.o fonctionsVerification.o
OBJETS_REGRESSION = testRegression.o tda_nuage.o regression.o
OBJETS_TIR = testTirArmes.o placer_dinos.o chargerMatrice.o fonctionsTirs.o fonctionsMenuHIP.o fonctionsStructJoueur.o
OBJETS_TIRSAFFICHAGE = testTirsAffichageJeu.o $(OBJ_ALL)

all: $(EXECUTABLES)

# Programme principal

./main: $(OBJETS_MAIN)
	gcc $^ -o $@ $(FLAGS_EDITION)

# Fichiers Tests

./test_archer: $(OBJETS_ARCHER)
	gcc $^ -o $@ $(FLAGS_EDITION)

./test_deplacement: $(OBJETS_DEPLA)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testAffichageDinosMap: $(OBJETS_AFF_DINOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testAffichageMenuHIP: $(OBJETS_AFFICHAGE_HIP)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testBombeDinosTours: $(OBJETS_BOMBE_DINOS_TOURS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testBombeDinosToursV2: $(OBJETS_BOMBE_DINOS_TOURS_V2)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testCollisions: $(OBJETS_COLLISIONS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsChangementTour: $(OBJETS_CHANGEMENT_TOUR)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsMenuPrinc: $(OBJETS_MENU_PRINC)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsPageFinPartie: $(OBJETS_PAGE_FIN_PARTIE)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsPagesInformations: $(OBJETS_PAGES_INFOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsRebonds: $(OBJETS_REBONDS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsStructJoueur: $(OBJETS_STRUCT_JOUEUR)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsTuerDinos: $(OBJETS_TUER_DINOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsVerification: $(OBJETS_VERIFICATION)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testRegression: $(OBJETS_REGRESSION)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testTirArmes: $(OBJETS_TIR)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testTirsAffichageJeu: $(OBJETS_TIRSAFFICHAGE)
	gcc $^ -o $@ $(FLAGS_EDITION)

# Compilation

%.o: $(REP_SRC)/%.c
	gcc $(FLAGS_COMPILATION) -c $< -o $@

%.o: $(REP_TEST)/%.c
	gcc $(FLAGS_COMPILATION) -c $< -o $@

# Suppression

clean:
	rm -f $(FIC_OBJETS) $(EXECUTABLES)

