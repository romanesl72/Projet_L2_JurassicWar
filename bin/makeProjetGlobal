fonctionsChangementTour.o \
fonctionsPageJeu.o \
fonctionsPlacementBombe.o \
fonctionsRebonds.o \
fonctionsTuerDinos.o

OBJETS_CHANGEMENT_TOUR = testFonctionsChangementTour.o  chargerMatrice.o fonctionsChangementTour.o fonctionsStructJoueur.o placer_dinos.o

OBJETS_PAGES_INFOS = testFonctionsPagesInformations.o \
chargerMatrice.o \
fonctionsChangementTour.o \
fonctionsMenuPrinc.o \
fonctionsPageJeu.o \
fonctionsPagesInformations.o \
fonctionsPlacementBombe.o \
fonctionsRebonds.o \
fonctionsStructJoueur.o \
fonctionsTuerDinos.o \
fonctionsVerification.o \
gestion_zones.o \
placer_dinos.o \
tda_nuage.o \

OBJETS_MAIN = main.o \
chargerMatrice.o \
fonctionsChangementTour.o \
fonctionsMenuPrinc.o \
fonctionsPageJeu.o \
fonctionsPlacementBombe.o \
fonctionsRebonds.o \
fonctionsStructJoueur.o \
fonctionsTuerDinos.o \
fonctionsVerification.o \
gestion_zones.o \
placer_dinos.o \
tda_nuage.o \

OBJETS_MENU_PRINC = testFonctionsMenuPrinc.o \
chargerMatrice.o \
fonctionsChangementTour.o \
fonctionsMenuPrinc.o \
fonctionsPageJeu.o \
fonctionsPlacementBombe.o \
fonctionsRebonds.o \
fonctionsStructJoueur.o \
fonctionsTuerDinos.o \
fonctionsVerification.o \
gestion_zones.o \
placer_dinos.o \
tda_nuage.o \

OBJETS_PLACEMENT_DINOS = main_test.o placer_dinos.o gestion_zones.o tda_nuage.o fonctionsVerification.o chargerMatrice.o
OBJETS_REBONDS = testFonctionsRebonds.o placer_dinos.o  fonctionsPlacementBombe.o fonctionsRebonds.o fonctionsStructJoueur.o fonctionsVerification.o chargerMatrice.o
OBJETS_TUER_DINOS = testFonctionsTuerDinos.o placer_dinos.o gestion_zones.o tda_nuage.o fonctionsPlacementBombe.o fonctionsRebonds.o fonctionsStructJoueur.o fonctionsVerification.o fonctionsTuerDinos.o chargerMatrice.o

OBJETS_VERIFICATION = testFonctionsVerification.o fonctionsVerification.o


all: $(EXECUTABLES)

# faire une ligne par exécutable

./main: $(OBJETS_MAIN)
	gcc $^ -o $@ $(FLAGS_EDITION)

./main_test: $(OBJETS_PLACEMENT_DINOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testBombeDinosTours: $(OBJETS_BOMBE_DINOS_TOURS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testBombeDinosToursV2: $(OBJETS_BOMBE_DINOS_TOURS_V2)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsChangementTour: $(OBJETS_CHANGEMENT_TOUR)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsMenuPrinc: $(OBJETS_MENU_PRINC)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsPagesInformations: $(OBJETS_PAGES_INFOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsRebonds: $(OBJETS_REBONDS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsTuerDinos: $(OBJETS_TUER_DINOS)
	gcc $^ -o $@ $(FLAGS_EDITION)

./testFonctionsVerification: $(OBJETS_VERIFICATION)
	gcc $^ -o $@ $(FLAGS_EDITION)

# Compilation

%.o: $(REP_SRC)/%.c
	gcc $(FLAGS_COMPILATION) -c $< -o $@

%.o: $(REP_TEST)/%.c
	gcc $(FLAGS_COMPILATION) -c $< -o $@

# Suppression

clean:
	rm -f $(FIC_OBJETS) $(EXECUTABLES)

